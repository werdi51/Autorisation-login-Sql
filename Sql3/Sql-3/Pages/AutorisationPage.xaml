<Page x:Class="Sql_3.Pages.AutorisationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Sql_3.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AutorisationPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="3*"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="1" Grid.Column="1" BorderThickness="5" BorderBrush="Black" CornerRadius="50">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <TextBlock TextAlignment="Center" VerticalAlignment="Center" FontSize="50">Авторизация</TextBlock>
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock FontSize="30">Напишите логин</TextBlock>
                    <TextBox Text="{Binding login}" Width="550" Height="50" Padding="10 2" FontSize="30" BorderThickness="2"/>
                </StackPanel>

                <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock FontSize="30">Напишите паролғ</TextBlock>
                    <TextBox Text="{Binding password}" Width="550" Height="50" Padding="10 2" FontSize="30" BorderThickness="2"/>
                </StackPanel>


                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">

                    <Border Width="300" Height="70" CornerRadius="20" Background="Green" Margin="0 0 10 0">
                        <Button Content="Зарегестрироваться" Background="Transparent" Foreground="White" FontSize="25" Click="Register_clisk" Margin="0,10,0,-10"/>
                    </Border>

                    <Border Width="100" Height="70" CornerRadius="20" Background="Green">
                        <Button Content="Авт-ия" Background="Transparent" Foreground="White" FontSize="25" Click="Auto_clisk" Margin="0,10,0,-10"/>
                    </Border>

                </StackPanel>
            </Grid>
        </Border>
        
        
    </Grid>
</Page>
