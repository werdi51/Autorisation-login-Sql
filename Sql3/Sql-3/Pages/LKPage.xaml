<Page x:Class="Sql_3.Pages.LKPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Sql_3.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LKPage">

    <Grid>
        <StackPanel>
            <TextBlock Text="{Binding fio,StringFormat='Привет {0}'}"></TextBlock>
            <Button Content="Exit" Background="Transparent" BorderBrush="Transparent" Foreground="White" FontSize="25" Click="Exit">
            </Button>
        </StackPanel>
    </Grid>
</Page>
